rule multiqc_trim:
    input:
        rules.trim_multiqc.input,
        config = base_dir / "resources/multiqc_config.yaml",
    output:
        html = "reports/multiqc.trim.html",
        data = "reports/multiqc_data.trim.zip",
    log:
        "logs/reports/multiqc.trim.log"
    benchmark:
        "benchmarks/reports/multiqc.trim.log"
    params:
        extra = f"--force " + check_cmd(config["report"]["multiqc"], forbidden_args = ["-n", "--filename", "-o", "--outdir", "--data-dir", "--no-data-dir", "-z", "--zip-data-dir", "--no-report", "--pdf", "--version", "-h", "--help"]),
    localrule: True
    threads: 1
    resources:
        mem = lambda w, attempt: f"{10 * attempt} GiB",
        runtime = lambda w, attempt: f"{30 * attempt} m",
    wrapper:
        wrapper_ver + "/bio/multiqc"

rule target_trim:
    input:
        rules.multiqc_trim.output,
        rules.trim_all.input.res,
    message:
        "Read trimming finished successfully!"



use rule multiqc_trim as multiqc_derep with:
    input:
        rules.trim_multiqc.input,
        rules.derep_multiqc.input,
        config = base_dir / "resources/multiqc_config.yaml",
    output:
        html = "reports/multiqc.derep.html",
        data = "reports/multiqc_data.derep.zip",
    log:
        "logs/reports/multiqc.derep.log"
    benchmark:
        "benchmarks/reports/multiqc.derep.log"

rule target_derep:
    input:
        rules.multiqc_derep.output,
        rules.derep_all.input.res,
    message:
        "Read dereplication finished successfully!"



use rule multiqc_derep as multiqc_taxon with:
    input:
        rules.trim_multiqc.input,
        rules.derep_multiqc.input,
        rules.taxon_multiqc.input,
        config = base_dir / "resources/multiqc_config.yaml",
    output:
        html = "reports/multiqc.taxon.html",
        data = "reports/multiqc_data.taxon.zip",
    log:
        "logs/reports/multiqc.taxon.log"
    benchmark:
        "benchmarks/reports/multiqc.taxon.log"

rule target_taxon:
    input:
        rules.multiqc_taxon.output,
        rules.taxon_all.input.res,
    message:
        "Taxonomic assignment finished successfully!"
    default_target: True
