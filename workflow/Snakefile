import pwd
import git
import json
import hashlib
import datetime
from snakemake.logging import logger
base_dir = Path(workflow.basedir)
repo = git.Repo(base_dir.parent)
logger.info(f"Snakemake version: {snakemake.common.__version__}")
logger.info("Git commit: {commit_hash} [{tag_flag}{commit_tag}] ({commit_time})".format(
        commit_hash = repo.head.commit.hexsha,
        commit_time = repo.head.commit.committed_datetime.strftime("%Y-%m-%d %H:%M:%S"),
        tag_flag = next(("" for tag in repo.tags if tag.commit == repo.head.commit), ">"),
        commit_tag = repo.git.tag(l=True, sort="authordate").split("\n")[-1],
))
logger.info("Run started: {time} ({user})".format(time = str(datetime.datetime.now()), user = pwd.getpwuid(os.getuid())[0]))
logger.info(f"Base dir: {base_dir}")
logger.info(f"Executing in: {workflow.workdir_init}")
config_json = json.dumps(config, sort_keys=True).encode('utf-8')
logger.info("Config JSON MD5: {md5sum} ({json})".format(md5sum = hashlib.md5(config_json).hexdigest(), json = config_json))
# Log current samples
logger.info("Samples:")
logger.info(samples.to_string(index=False))
logger.info("Units:")
logger.info(units.index)



####################
### Target Rules ###
