import pandas as pd
from urllib.parse import urlparse, urlunparse

snakemake.utils.min_version("9.13.5")

# Define wrapper versions
wrapper_ver = "v7.9.1"

# Define base URL
baseurl = urlparse(workflow.current_basedir.get_path_or_uri(secret_free=True))


include: "rules/utils.smk"
include: "rules/setup.smk"


# Load modules
module workflow_trim:
    snakefile:
        github("GeoGenetics/ngs-trim", path="workflow/Snakefile", tag="v0.5.5")
    config:
        {"units": units, "cfg": config["trim"]}


use rule * from workflow_trim as trim_*


module workflow_derep:
    snakefile:
        github("GeoGenetics/ngs-derep", path="workflow/Snakefile", tag="v0.5.1")
    config:
        {"units": units, "cfg": config["derep"]}


use rule * from workflow_derep as derep_*


d1 = ["benchmarks", "logs", "reports", "results", "stats", "temp"]
d2 = ["reads", "shards", "aligns", "metadmg", "reports"]
from itertools import product


module workflow_taxon_prefilter:
    snakefile:
        github("GeoGenetics/ngs-taxon", path="workflow/Snakefile", tag="v0.11.1")
    config:
        {"units": units, "cfg": config["prefilter"]}
    replace_prefix:
        {f"{d1}/{d2}/": f"{d1}/prefilter_{d2}/" for d1, d2 in product(d1, d2)}


use rule * from workflow_taxon_prefilter as taxon_prefilter_*


module workflow_taxon:
    snakefile:
        github("GeoGenetics/ngs-taxon", path="workflow/Snakefile", tag="v0.11.1")
    config:
        {"units": units, "cfg": config["euk"]}


use rule * from workflow_taxon as taxon_*


include: "rules/prefilter.smk"


onsuccess:
    print("aeDNA workflow finished successfully!")


onerror:
    print("aeDNA workflow finished with an error!")


